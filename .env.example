# ─────────────────────────────────────────────────────────────────────────────
# TEAL Jewellery – Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# ── Database (SQLite via Prisma) ──────────────────────────────────────────────
# SQLite is the default for local development – no server installation needed.
# The database file is stored at prisma/dev.db (auto-created on first run).
DATABASE_URL="file:./dev.db"

# ── Sessions ─────────────────────────────────────────────────────────────────
# Generate with: node -e "require('crypto').randomBytes(64).toString('hex')|xargs echo"
SESSION_SECRET=change-me-to-a-long-random-string-in-production

# ── CSRF ─────────────────────────────────────────────────────────────────────
CSRF_SECRET=change-me-to-another-long-random-string

# ── Admin User (seed script) ──────────────────────────────────────────────────
ADMIN_EMAIL=admin@teal.dev
ADMIN_PASSWORD=Admin@12345!

# ── Payment Provider ──────────────────────────────────────────────────────────
# Options: razorpay | stripe
PAYMENT_PROVIDER=razorpay
CURRENCY=INR

# Razorpay (test mode) – get keys at https://dashboard.razorpay.com/
RAZORPAY_KEY_ID=<your-razorpay-test-key-id>
RAZORPAY_KEY_SECRET=<your-razorpay-test-key-secret>
RAZORPAY_WEBHOOK_SECRET=<your-razorpay-webhook-secret>

# Stripe (test mode) – get keys at https://dashboard.stripe.com/test/apikeys
# Replace the placeholders below with your actual test keys (never commit real keys)
STRIPE_SECRET_KEY=<your-stripe-test-secret-key>
STRIPE_PUBLISHABLE_KEY=<your-stripe-test-publishable-key>
STRIPE_WEBHOOK_SECRET=<your-stripe-webhook-secret>

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Leave blank for Ethereal (dev auto-config) or set for production SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="TEAL Jewellery <noreply@teal.dev>"

# ── App URL (for email links) ────────────────────────────────────────────────
BASE_URL=http://localhost:3000

# ── Dev Helpers ───────────────────────────────────────────────────────────────
# Skip email verification in local dev (set to true to auto-verify on register)
DEV_SKIP_EMAIL_VERIFY=true

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=debug
