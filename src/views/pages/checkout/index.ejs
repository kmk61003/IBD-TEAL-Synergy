<div class="container py-5">
  <div class="row">
    <div class="col-lg-7">
      <h1 class="mb-4">Checkout</h1>

      <% if (errors && errors.length) { %>
        <div class="alert alert-danger">
          <ul class="mb-0 small">
            <% errors.forEach(e => { %><li><%= e.msg %></li><% }) %>
          </ul>
        </div>
      <% } %>

      <div class="card border-0 shadow-sm mb-4">
        <div class="card-body p-4">
          <h5 class="mb-3">Delivery Details</h5>
          <form method="POST" action="/checkout/order" novalidate>
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">

            <div class="mb-3">
              <label for="fullName" class="form-label fw-semibold">Full Name <span class="text-danger">*</span></label>
              <input type="text" class="form-control" id="fullName" name="fullName"
                value="<%= old.fullName || (user ? user.name : '') %>" required autocomplete="name">
            </div>

            <div class="mb-3">
              <label for="address1" class="form-label fw-semibold">Address Line 1 <span class="text-danger">*</span></label>
              <input type="text" class="form-control" id="address1" name="address1"
                value="<%= old.address1 || '' %>" required autocomplete="address-line1">
            </div>

            <div class="mb-3">
              <label for="address2" class="form-label fw-semibold">Address Line 2</label>
              <input type="text" class="form-control" id="address2" name="address2"
                value="<%= old.address2 || '' %>" autocomplete="address-line2">
            </div>

            <div class="row g-3 mb-3">
              <div class="col-md-6">
                <label for="city" class="form-label fw-semibold">City <span class="text-danger">*</span></label>
                <input type="text" class="form-control" id="city" name="city"
                  value="<%= old.city || '' %>" required autocomplete="address-level2">
              </div>
              <div class="col-md-3">
                <label for="postcode" class="form-label fw-semibold">Postcode <span class="text-danger">*</span></label>
                <input type="text" class="form-control" id="postcode" name="postcode"
                  value="<%= old.postcode || '' %>" required autocomplete="postal-code">
              </div>
              <div class="col-md-3">
                <label for="country" class="form-label fw-semibold">Country <span class="text-danger">*</span></label>
                <select class="form-select" id="country" name="country" autocomplete="country">
                  <option value="GB" <%= (old.country || 'GB') === 'GB' ? 'selected' : '' %>>United Kingdom</option>
                  <option value="US" <%= old.country === 'US' ? 'selected' : '' %>>United States</option>
                  <option value="IN" <%= old.country === 'IN' ? 'selected' : '' %>>India</option>
                  <option value="AU" <%= old.country === 'AU' ? 'selected' : '' %>>Australia</option>
                </select>
              </div>
            </div>

            <button type="submit" class="btn btn-dark w-100 fw-semibold py-2 mt-2">
              <i class="bi bi-lock me-2"></i>Continue to Payment
            </button>
          </form>
        </div>
      </div>
    </div>

    <!-- Order Summary Sidebar -->
    <div class="col-lg-5">
      <div class="card border-0 shadow-sm sticky-top" style="top:80px">
        <div class="card-body">
          <h5 class="mb-3">Your Bag</h5>
          <% cart.items.forEach(item => { %>
          <div class="d-flex justify-content-between align-items-center mb-2 small">
            <span class="text-muted">
              <%= item.product.title %>
              <span class="badge bg-secondary ms-1"><%= item.qty %></span>
            </span>
            <span class="fw-semibold"><%= item.lineTotalFormatted %></span>
          </div>
          <% }) %>
          <hr>
          <div class="d-flex justify-content-between fw-bold">
            <span>Total</span>
            <span><%= cart.subtotalFormatted %></span>
          </div>
          <div class="mt-3 text-center">
            <small class="text-muted">
              <i class="bi bi-lock-fill me-1 text-success"></i>
              Demo: no real payment will be charged
            </small>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
