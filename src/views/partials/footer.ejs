<footer class="teal-footer mt-auto py-4">
  <div class="container">
    <div class="row gy-3">
      <div class="col-md-4">
        <h5 class="text-warning fw-bold">◆ TEAL Jewellery</h5>
        <p class="text-muted small">Every piece tells a story. What's yours?</p>
      </div>
      <div class="col-md-2">
        <h6 class="fw-semibold">Shop</h6>
        <ul class="list-unstyled small">
          <li><a href="/catalog" class="text-muted text-decoration-none">All Collections</a></li>
          <li><a href="/catalog?category=Rings" class="text-muted text-decoration-none">Rings</a></li>
          <li><a href="/catalog?category=Necklaces" class="text-muted text-decoration-none">Necklaces</a></li>
          <li><a href="/catalog?category=Earrings" class="text-muted text-decoration-none">Earrings</a></li>
        </ul>
      </div>
      <div class="col-md-2">
        <h6 class="fw-semibold">Account</h6>
        <ul class="list-unstyled small">
          <% if (user) { %>
            <li><a href="/orders" class="text-muted text-decoration-none">My Orders</a></li>
            <li><a href="/auth/logout" class="text-muted text-decoration-none">Sign Out</a></li>
          <% } else { %>
            <li><a href="/auth/login" class="text-muted text-decoration-none">Sign In</a></li>
            <li><a href="/auth/register" class="text-muted text-decoration-none">Register</a></li>
          <% } %>
        </ul>
      </div>
      <div class="col-md-4 text-md-end">
        <p class="text-muted small mb-1">🔒 Secure checkout &nbsp;|&nbsp; 🔄 Free returns</p>
        <p class="text-muted small">✦ Certificate of Authenticity</p>
      </div>
    </div>
    <hr class="border-secondary">
    <p class="text-center text-muted small mb-0">
      &copy; <%= new Date().getFullYear() %> TEAL Jewellery. All rights reserved.
      Built with <span class="text-danger">♥</span> for IBD Hackathon.
    </p>
  </div>
</footer>
